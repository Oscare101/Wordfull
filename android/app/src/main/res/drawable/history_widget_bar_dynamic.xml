<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- minimum visible bar -->
    <item
        android:gravity="bottom"
        android:height="10dp"
        android:drawable="@drawable/history_widget_bar_fill" />

    <!-- scalable extra height controlled by imageLevel -->
    <item android:gravity="bottom">
        <scale
            android:drawable="@drawable/history_widget_bar_fill"
            android:scaleGravity="bottom"
            android:useLevel="true"
            android:scaleHeight="1.0"
            android:scaleWidth="1.0" />
    </item>

</layer-list>